# Backend API URL that serves FastAPI (for frontend config.js this value is used manually)
API_BASE_URL="https://your-backend.example.com"

# Spotify app credentials
SPOTIPY_CLIENT_ID="your_spotify_client_id"
SPOTIPY_CLIENT_SECRET="your_spotify_client_secret"
SPOTIPY_REDIRECT_URI="https://your-backend.example.com/api/spotify/callback"

# Session/cookies and CORS
APP_SESSION_SECRET="replace_with_a_long_random_secret"
CORS_ALLOWED_ORIGINS="https://your-vercel-domain.vercel.app,https://your-custom-domain.com"
FRONTEND_URL="https://your-vercel-domain.vercel.app"
